# database settings
# Set DB_CLIENT to 'mysql2' for MySQL/MariaDB or 'pg' for PostgreSQL
# DB_CLIENT=mysql2
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_USER=root
# DB_PASS=root123
# DB_NAME=pustaka

# For PostgreSQL (Uncomment and update if using pg)
DB_CLIENT=pg
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=admin
DB_PASS=admin123
DB_NAME=pustaka
DB_SSL=false
JWT_SECRET=a3f7c9d1e4b6082f5a9c3d7e1b4f8026d9a2e5c8f1b4d7a0e3c6f9b2d5a8c1e4
PORT=5000
SESSION_TTL_MS=604800000
ALLOW_DEV_TOKEN=false
ALLOW_QUERY_TOKEN=false
AI_VECTOR_LAZY_INIT=true
AI_VECTOR_INIT_BATCH_SIZE=250

# Opsional Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379