  "scripts": {
    "dev": "node server/scripts/init_db_choice.js && concurrently \"node --watch server/index.js\" \"npm run worker:bullmq\" \"npm run worker:polling\" \"npx wait-on tcp:127.0.0.1:5000 && vite --host 0.0.0.0 --port 5173\"",
    "db:reset": "node server/scripts/init_db_choice.js && npx knex migrate:rollback --all && npx knex migrate:latest",
    "db:wipe": "node server/wipeDb.js",
    "server": "node --watch server/index.js",
    "worker": "set IS_WORKER=true&& node --watch server/worker.js",
    "worker:bullmq": "set IS_WORKER=true&& set VIPS_WARNING=0&& set G_MESSAGES_DEBUG=none&& node --watch server/worker.js --mode=bullmq",
    "worker:polling": "set IS_WORKER=true&& set VIPS_WARNING=0&& set G_MESSAGES_DEBUG=none&& node --watch server/worker.js --mode=polling",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test:server": "vitest run --dir server/tests",
    "test": "vitest"
  },
  "description": "This template provides a minimal setup to get React working in Vite with HMR and some ESLint rules.",
